# Database mode: postgres | mongo
PAYLOAD_DB_MODE=postgres

# Used by postgres mode (required when PAYLOAD_DB_MODE=postgres)
POSTGRES_URI=postgresql://postgres:postgres@127.0.0.1:5432/blackforest-payload

# Used by mongo mode (required when PAYLOAD_DB_MODE=mongo)
MONGODB_URI=mongodb://127.0.0.1/blackforest-payload

# Backward-compatible fallback used by existing scripts/config.
# Keep this aligned with your active mode if needed.
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:5432/blackforest-payload
PAYLOAD_SECRET=YOUR_SECRET_HERE
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_BUCKET=YOUR_R2_BUCKET_NAME
S3_REGION=auto
NEXT_PUBLIC_S3_PUBLIC_URL=https://<public-bucket-subdomain>.r2.dev
S3_PUBLIC_URL=https://<public-bucket-subdomain>.r2.dev
BRANCH_PIN_DAILY_SECRET=CHANGE_ME_DAILY_BRANCH_PIN_SEED
